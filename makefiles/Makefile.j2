# Generated by {{ script }} — do not edit by hand.
# Regenerate with: python3 {{ script }} makefile > {{ output_makefile }}
SHELL := /bin/bash
RUN   := python3 {{ script }}

{% if asc is defined %}
_ASC_DEP := $(wildcard {{ asc }})
{% elif expath is defined %}
EXPATH   := {{ expath }}
{% endif %}
SVG_FILES := {{ svg_files_str }}
NET_FILES := {{ net_files_str }}
RAW_FILES := {{ raw_files_str }}
PNG_FILES := {{ png_files_str }}

.PHONY: all svg netlist sim plots replot report clean
all: svg netlist sim plots report

# Rebuild this file whenever the script changes.
{{ output_makefile }}: {{ script }}
	python3 {{ script }} makefile > {{ output_makefile }}

# ── Schematics ────────────────────────────────────────────────────────────────
svg: $(SVG_FILES)

{% for c in circuits %}
{{ build }}/{{ c.slug }}/schematic.svg: {{ c.asc_dep }} {{ script }}
	@mkdir -p $(@D)
	$(RUN) svg --circuit {{ c.slug }}

{% endfor %}
# ── Netlist export ────────────────────────────────────────────────────────────
netlist: $(NET_FILES)

{% for c in circuits %}
{{ c.net_path }}: {{ c.asc_dep }} {{ script }}
	$(RUN) netlist --circuit {{ c.slug }}

{% endfor %}
# ── Simulations ───────────────────────────────────────────────────────────────
sim: $(RAW_FILES)

{% for c in circuits %}
{{ c.raw_targets_str }} &: {{ c.net_path }} {{ script }}
	@mkdir -p $(@D)
	$(RUN) sim --circuit {{ c.slug }}

{% endfor %}
# ── Plots ─────────────────────────────────────────────────────────────────────
plots: $(PNG_FILES)

{% for c in circuits %}
{% for entry in c.plot_entries %}
{{ build }}/{{ c.slug }}/{{ entry.stem }}.png: {{ build }}/{{ c.slug }}/{{ entry.raw_stem }}.raw {{ build }}/{{ c.slug }}/schematic.svg {{ script }}
	$(RUN) plots --circuit {{ c.slug }} --stem {{ entry.stem }}

{% endfor %}
{% endfor %}
replot:
	$(RUN) plots

# ── Report ────────────────────────────────────────────────────────────────────
REPORTS := {{ report_paths | join(' ') }}

report: $(REPORTS)

$(REPORTS): $(SVG_FILES) $(PNG_FILES)
	$(RUN) report

# ── Housekeeping ──────────────────────────────────────────────────────────────
clean:
	rm -rf {{ build }}
